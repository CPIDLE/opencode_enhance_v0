{
  "$schema": "https://opencode.ai/config.json",
  "model": "google/gemini-3.1-pro-preview",
  "provider": {
    "google": {
      "options": {
        "apiKey": "{env:GEMINI_API_KEY}"
      },
      "models": {
        "gemini-3.1-pro-preview": {},
        "gemini-3-flash-preview": {},
        "gemini-2.5-pro": {},
        "gemini-2.5-flash": {}
      }
    }
  },
  "mcp": {
    "playwright": {
      "type": "local",
      "enabled": false,
      "command": ["npx", "-y", "@playwright/mcp"]
    },
    "windows-mcp": {
      "type": "local",
      "enabled": false,
      "command": ["<uvx.exe 絕對路徑，執行 where uvx 取得>", "windows-mcp"]
    },
    "google-workspace": {
      "type": "local",
      "enabled": false,
      "command": ["npx", "-y", "google-workspace-mcp", "serve"]
    }
  }
}
